    <script>
        function resizeMap() {
            const img = document.getElementById('map-img');
            const map = document.getElementsByName('metalmap')[0];
            if (!img || !map) return;

            const originalWidth = 1000;
            
            const scale = img.clientWidth / originalWidth;
            const baseCoords = [
                [0, 0, 500, 375],       
                [500, 0, 1000, 375],    
                [0, 375, 500, 666],     
                [500, 375, 1000, 666],  
                [0, 666, 500, 1000],    
                [500, 666, 1000, 1000]  
            ];

            const areas = map.getElementsByTagName('area');
            for (let i = 0; i < areas.length; i++) {
                if(baseCoords[i]) {
                    const scaledCoords = baseCoords[i].map(coord => Math.round(coord * scale));
                    areas[i].coords = scaledCoords.join(',');
                }
            }
        }

        window.addEventListener('load', resizeMap);
        window.addEventListener('resize', resizeMap);
    </script>
