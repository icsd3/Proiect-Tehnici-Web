<!DOCTYPE html>
<html lang="ro">

<head>
    <%- include("../fragmente/head", { titluPagina: typeof locals.titluPagina !== "undefined" ? locals.titluPagina : "Produs TheMetalVault" }) %>
</head>

<body id="top" class="pagina-produs">
    <%- include("../fragmente/header") %>

    <main>
        <div id="grid-pagina" class="grid-pagina--produs">
            <section id="produs-unic">
                <%
                    const luniRo = ["Ianuarie", "Februarie", "Martie", "Aprilie", "Mai", "Iunie", "Iulie", "August", "Septembrie", "Octombrie", "Noiembrie", "Decembrie"];
                    const zileRo = ["Duminica", "Luni", "Marti", "Miercuri", "Joi", "Vineri", "Sambata"];
                    const dataCalendaristica = new Date(locals.produs.data_adaugare);
                    const dataProdus = {
                        iso: dataCalendaristica.toISOString().slice(0, 10),
                        text: `${dataCalendaristica.getDate()}-${luniRo[dataCalendaristica.getMonth()]}-${dataCalendaristica.getFullYear()} [${zileRo[dataCalendaristica.getDay()]}]`
                    };
                    const taguriProdus = locals.produs.taguri.split(",").map((tag) => tag.trim()).filter(Boolean);
                    const imaginiProdus = Array.isArray(locals.produs.imagini) && locals.produs.imagini.length
                        ? locals.produs.imagini
                        : [{ src: locals.produs.imagine, alt: `${locals.produs.nume} - imagine principala` }];
                %>

                <p class="produs-unic__breadcrumb"><a href="/produse">Inapoi la produse</a></p>
                <h2><%= locals.produs.nume %></h2>

                <article class="produs-unic__card">
                    <div class="produs-unic__media">
                        <div class="produs-unic__galerie" data-galerie-produs>
                            <img
                                class="produs-unic__imagine-curenta"
                                src="<%= imaginiProdus[0].src %>"
                                alt="<%= imaginiProdus[0].alt %>"
                                data-galerie-imagine
                            >

                            <% if (imaginiProdus.length > 1) { %>
                                <div class="produs-unic__galerie-actiuni" aria-label="Navigare imagini produs">
                                    <button class="btn btn-outline-primary" type="button" title="Imaginea precedenta" aria-label="Imaginea precedenta" data-galerie-prev>
                                        <i class="bi bi-chevron-left" aria-hidden="true"></i>
                                    </button>
                                    <span class="produs-unic__galerie-contor" aria-live="polite" data-galerie-contor>1 / <%= imaginiProdus.length %></span>
                                    <button class="btn btn-outline-primary" type="button" title="Imaginea urmatoare" aria-label="Imaginea urmatoare" data-galerie-next>
                                        <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                    </button>
                                </div>

                                <div class="produs-unic__miniaturi" aria-label="Selectare imagine produs">
                                    <% imaginiProdus.forEach(function (imagine, index) { %>
                                        <button
                                            class="produs-unic__miniatura <%= index === 0 ? "produs-unic__miniatura--activa" : "" %>"
                                            type="button"
                                            aria-label="Afiseaza imaginea <%= index + 1 %>"
                                            aria-pressed="<%= index === 0 ? "true" : "false" %>"
                                            data-galerie-index="<%= index %>"
                                            data-galerie-src="<%= imagine.src %>"
                                            data-galerie-alt="<%= imagine.alt %>"
                                        >
                                            <img src="<%= imagine.src %>" alt="">
                                        </button>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <p class="produs-unic__descriere"><%= locals.produs.descriere %></p>

                    <div class="produs-unic__detalii produs-unic__detalii--principale">
                        <p><b>ID:</b> <span><%= locals.produs.id %></span></p>
                        <p><b>Categorie:</b> <span><%= locals.produs.categorie %></span></p>
                        <p><b>Subcategorie:</b> <span><%= locals.produs.subcategorie %></span></p>
                        <p><b>Pret:</b> <span><%= Number(locals.produs.pret).toFixed(2) %> lei</span></p>
                    </div>

                    <div class="produs-unic__detalii produs-unic__detalii--secundare">
                        <p><b>Greutate:</b> <span><%= locals.produs.greutate_grame %> g</span></p>
                        <p><b>Data adaugare:</b> <time datetime="<%= dataProdus.iso %>"><%= dataProdus.text %></time></p>
                        <p><b>Culoare:</b> <span><%= locals.produs.culoare %></span></p>
                        <p><b>Editie limitata:</b> <span><%= locals.produs.editie_limitata ? "da" : "nu" %></span></p>
                        <p><b>Stoc disponibil:</b> <span><%= locals.produs.stoc %></span></p>

                        <div class="produs-unic__taguri">
                            <b>Taguri:</b>
                            <ul>
                                <% for (const tag of taguriProdus) { %>
                                    <li><%= tag %></li>
                                <% } %>
                            </ul>
                        </div>
                    </div>
                </article>
            </section>
        </div>
    </main>

    <%- include("../fragmente/footer") %>
    <script src="/resurse/js/produs.js"></script>
</body>

</html>
