<!DOCTYPE html>
<html lang="ro">

<head>
    <%- include("../fragmente/head", { titluPagina: "Produse TheMetalVault" }) %>
</head>

<body id="top" class="pagina-produse">
    <%- include("../fragmente/header") %>

    <main>
        <div id="grid-pagina">
            <section id="produse">
                <% const categorieActivaCurenta = typeof categorieActiva === "string" ? categorieActiva : ""; %>
                <h2><%= categorieActivaCurenta ? `Produse - ${categorieActivaCurenta}` : "Produse" %></h2>
                <% const listaProduse = typeof produse !== "undefined" ? produse : []; %>
                <%
                    const luniRo = ["Ianuarie", "Februarie", "Martie", "Aprilie", "Mai", "Iunie", "Iulie", "August", "Septembrie", "Octombrie", "Noiembrie", "Decembrie"];
                    const zileRo = ["Duminica", "Luni", "Marti", "Miercuri", "Joi", "Vineri", "Sambata"];

                    function dataProdus(dataCalendaristica) {
                        const data = new Date(dataCalendaristica);
                        return {
                            iso: data.toISOString().slice(0, 10),
                            text: `${data.getDate()}-${luniRo[data.getMonth()]}-${data.getFullYear()} [${zileRo[data.getDay()]}]`
                        };
                    }

                    const categoriiProduse = Array.isArray(categoriiProduseMeniu) && categoriiProduseMeniu.length
                        ? categoriiProduseMeniu
                        : [...new Set(listaProduse.map((produs) => produs.categorie))].sort();
                    const culoriProduse = [...new Set(listaProduse.map((produs) => produs.culoare))].sort();
                    const subcategoriiProduse = [...new Set(listaProduse.map((produs) => produs.subcategorie))].sort();
                    const taguriProduse = [...new Set(listaProduse.flatMap((produs) => produs.taguri.split(",").map((tag) => tag.trim()).filter(Boolean)))].sort();
                    const preturiProduse = listaProduse.map((produs) => Number(produs.pret));
                    const pretMinim = (preturiProduse.length ? Math.min(...preturiProduse) : 0).toFixed(2);
                    const pretMaxim = (preturiProduse.length ? Math.max(...preturiProduse) : 0).toFixed(2);
                %>

                <% if (listaProduse.length) { %>
                    <section id="sectiune-filtrare-produse" class="filtre-produse card border-info-subtle shadow-sm" aria-labelledby="titlu-filtre-produse">
                        <div class="card-body p-3 p-lg-4">
                            <div class="filtre-produse__header d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                                <div>
                                    <h3 id="titlu-filtre-produse" class="card-title mb-1">Filtrare produse</h3>
                                </div>
                            </div>

                            <p id="mesaj-validare-filtre" class="filtre-produse__mesaj alert alert-danger mb-3" role="alert" aria-live="polite" hidden></p>

                            <div class="row g-3">
                                <div class="col-12 col-lg-6 col-xl-4">
                                    <div class="filtre-produse__camp card h-100 border-info-subtle bg-body-tertiary">
                                        <div class="card-body">
                                            <label class="form-label fw-semibold mb-2" for="filtru-text">
                                                <i class="bi bi-tags-fill me-2" aria-hidden="true"></i>Tag cautat
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                                                <input class="form-control" id="filtru-text" name="filtru-text" type="text" placeholder="subsir dintr-un tag">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-lg-6 col-xl-4">
                                    <div class="filtre-produse__camp card h-100 border-info-subtle bg-body-tertiary">
                                        <div class="card-body">
                                            <label class="form-label fw-semibold mb-2" for="filtru-nume">
                                                <i class="bi bi-vinyl-fill me-2" aria-hidden="true"></i>Nume produs
                                            </label>
                                            <input class="form-control" id="filtru-nume" name="filtru-nume" list="lista-nume-produse" placeholder="oricare">
                                            <datalist id="lista-nume-produse">
                                                <% for (const produs of listaProduse) { %>
                                                    <option value="<%= produs.nume %>"></option>
                                                <% } %>
                                            </datalist>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-xl-4">
                                    <div class="filtre-produse__camp card h-100 border-info-subtle bg-body-tertiary">
                                        <div class="card-body">
                                            <label class="form-label fw-semibold mb-2" for="filtru-culoare">
                                                <i class="bi bi-palette-fill me-2" aria-hidden="true"></i>Culoare
                                            </label>
                                            <select class="form-select" id="filtru-culoare" name="filtru-culoare">
                                                <option value="">oricare</option>
                                                <% for (const culoare of culoriProduse) { %>
                                                    <option value="<%= culoare %>"><%= culoare %></option>
                                                <% } %>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-xl-5">
                                    <fieldset class="filtre-produse__grup filtre-produse__grup--categorie card h-100 border-info-subtle bg-body-tertiary" aria-labelledby="titlu-filtru-categorie">
                                        <div class="card-body">
                                            <legend id="titlu-filtru-categorie" class="filtre-produse__grup-titlu">
                                                <i class="bi bi-collection-play-fill me-2" aria-hidden="true"></i>Categorie
                                            </legend>
                                            <div class="d-flex flex-wrap gap-2" role="radiogroup" aria-labelledby="titlu-filtru-categorie">
                                                <input class="btn-check" type="radio" name="filtru-categorie" id="filtru-categorie-toate" value="" <%= !categorieActivaCurenta ? "checked" : "" %>>
                                                <label class="btn btn-outline-primary" for="filtru-categorie-toate">orice categorie</label>
                                                <% for (const categorie of categoriiProduse) { %>
                                                    <% const idCategorie = `filtru-categorie-${categorie.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`; %>
                                                    <input class="btn-check" type="radio" name="filtru-categorie" id="<%= idCategorie %>" value="<%= categorie %>" <%= categorieActivaCurenta === categorie ? "checked" : "" %>>
                                                    <label class="btn btn-outline-primary" for="<%= idCategorie %>"><%= categorie %></label>
                                                <% } %>
                                            </div>
                                        </div>
                                    </fieldset>
                                </div>

                                <div class="col-12 col-xl-7">
                                    <div class="filtre-produse__camp filtre-produse__camp--taguri card h-100 border-info-subtle bg-body-tertiary">
                                        <div class="card-body">
                                            <label class="form-label fw-semibold mb-2" for="filtru-taguri">
                                                <i class="bi bi-slash-circle-fill me-2" aria-hidden="true"></i>Selectati valorile pe care NU le doriti
                                            </label>
                                            <select class="form-select" id="filtru-taguri" name="filtru-taguri" multiple size="5">
                                                <% for (const tag of taguriProduse) { %>
                                                    <option value="<%= tag %>"><%= tag %></option>
                                                <% } %>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-xl-8">
                                    <div class="filtre-produse__camp filtre-produse__camp--range card h-100 border-info-subtle bg-body-tertiary">
                                        <div class="card-body">
                                            <label class="form-label fw-semibold d-flex align-items-center gap-2 mb-3" for="filtru-pret">
                                                <i class="bi bi-sliders2 me-1" aria-hidden="true"></i>Pret maxim
                                                <output id="valoare-filtru-pret" class="badge text-bg-primary ms-auto" for="filtru-pret"><%= pretMaxim %> lei</output>
                                            </label>
                                            <input class="form-range filtre-produse__slider" id="filtru-pret" name="filtru-pret" type="range" min="<%= pretMinim %>" max="<%= pretMaxim %>" value="<%= pretMaxim %>" step="0.01">
                                            <div class="filtre-produse__range d-flex flex-wrap justify-content-between gap-2 small text-body-secondary">
                                                <span><%= pretMinim %> lei</span>
                                                <span><%= pretMaxim %> lei</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="filtre-produse__camp filtre-produse__camp--checkbox card h-100 border-info-subtle bg-body-tertiary">
                                        <div class="card-body d-flex align-items-center">
                                            <input class="btn-check" id="filtru-editie-limitata" name="filtru-editie-limitata" type="checkbox" autocomplete="off">
                                            <label class="btn btn-outline-warning w-100 d-flex align-items-center justify-content-center gap-2 py-3" for="filtru-editie-limitata">
                                                <i class="bi bi-stars" aria-hidden="true"></i>
                                                <span>Doar editii limitate</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-xl-7">
                                    <fieldset class="filtre-produse__grup filtre-produse__grup--subcategorii card border-info-subtle bg-body-tertiary" aria-labelledby="titlu-filtru-subcategorie">
                                        <div class="card-body">
                                            <legend id="titlu-filtru-subcategorie" class="filtre-produse__grup-titlu">
                                                <i class="bi bi-ui-checks-grid me-2" aria-hidden="true"></i>Subcategorie
                                            </legend>
                                            <div class="d-flex flex-wrap gap-2">
                                                <% for (const subcategorie of subcategoriiProduse) { %>
                                                    <% const idSubcategorie = `filtru-subcategorie-${subcategorie.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`; %>
                                                    <input class="btn-check" type="checkbox" name="filtru-subcategorie" id="<%= idSubcategorie %>" value="<%= subcategorie %>" checked autocomplete="off">
                                                    <label class="btn btn-outline-secondary" for="<%= idSubcategorie %>"><%= subcategorie %></label>
                                                <% } %>
                                            </div>
                                        </div>
                                    </fieldset>
                                </div>

                                <div class="col-12 col-md-6 col-xl-5">
                                    <div class="filtre-produse__camp filtre-produse__camp--descriere card h-100 border-info-subtle bg-body-tertiary">
                                        <div class="card-body">
                                            <div class="form-floating filtre-produse__floating">
                                                <textarea class="form-control" id="filtru-descriere" name="filtru-descriere" placeholder="Cuvinte in descriere" style="height: 11rem"></textarea>
                                                <label for="filtru-descriere"><i class="bi bi-chat-square-text-fill" aria-hidden="true"></i><span>Cuvinte in descriere</span></label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="filtre-produse__actiuni d-grid gap-2 d-sm-flex justify-content-sm-end">
                                        <button id="btn-filtreaza" class="btn btn-primary" type="button" aria-label="Filtreaza produsele">
                                            <i class="bi bi-funnel-fill" aria-hidden="true"></i>
                                            <span class="filtre-produse__btn-text d-none d-sm-inline">Filtreaza</span>
                                        </button>
                                        <button id="btn-sortare-asc" class="btn btn-outline-primary" type="button" aria-label="Sorteaza ascendent">
                                            <i class="bi bi-sort-alpha-down" aria-hidden="true"></i>
                                            <span class="filtre-produse__btn-text d-none d-sm-inline">Sorteaza ascendent</span>
                                        </button>
                                        <button id="btn-sortare-desc" class="btn btn-outline-primary" type="button" aria-label="Sorteaza descendent">
                                            <i class="bi bi-sort-alpha-up-alt" aria-hidden="true"></i>
                                            <span class="filtre-produse__btn-text d-none d-sm-inline">Sorteaza descendent</span>
                                        </button>
                                        <button id="btn-calculeaza" class="btn btn-outline-success" type="button" aria-label="Calculeaza suma produselor afisate">
                                            <i class="bi bi-calculator-fill" aria-hidden="true"></i>
                                            <span class="filtre-produse__btn-text d-none d-sm-inline">Calculeaza suma</span>
                                        </button>
                                        <button id="btn-reseteaza-filtre" class="btn btn-outline-danger filtre-produse__reset" type="button" aria-label="Reseteaza filtrele">
                                            <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                                            <span class="filtre-produse__btn-text d-none d-sm-inline">Reseteaza</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

	                    <div class="lista-produse row row-cols-1 row-cols-lg-3 g-4">
	                        <% for (const produs of listaProduse) { %>
	                            <% const dataAfisata = dataProdus(produs.data_adaugare); %>
                            <article
                                id="ar_ent_<%= produs.id %>"
                                class="card-produs col <%= produs.categorie %>"
                                data-nume="<%= produs.nume %>"
                                data-descriere="<%= produs.descriere %>"
                                data-categorie="<%= produs.categorie %>"
                                data-pret="<%= produs.pret %>"
                                data-subcategorie="<%= produs.subcategorie %>"
                                data-culoare="<%= produs.culoare %>"
                                data-taguri="<%= produs.taguri %>"
                                data-editie-limitata="<%= produs.editie_limitata ? "da" : "nu" %>"
                            >
                                <div class="card h-100 border-info-subtle shadow-sm bg-body-tertiary">
                                    <div class="card-header d-flex flex-wrap gap-2 align-items-center justify-content-between">
                                        <span class="badge text-bg-primary card-produs__categorie"><%= produs.categorie %></span>
                                        <% if (produs.editie_limitata) { %>
                                            <span class="badge text-bg-secondary text-dark">Editie limitata</span>
                                        <% } else { %>
                                            <span class="badge text-bg-warning text-light">Standard</span>
	                                        <% } %>
	                                    </div>
	
	                                    <button class="card-produs__media-link card-produs__media-buton" type="button" aria-haspopup="dialog" aria-controls="modal-produs-<%= produs.id %>" data-modal-produs="modal-produs-<%= produs.id %>">
	                                        <img class="card-img-top" src="<%= produs.imagine %>" alt="<%= produs.nume %>">
	                                    </button>
	
	                                    <div class="card-body d-flex flex-column gap-3">
	                                        <div>
	                                            <h3 class="card-title h5 mb-2">
	                                                <a class="card-produs__titlu-link text-decoration-none" href="/produs/<%= produs.id %>"><%= produs.nume %></a>
	                                            </h3>
	                                            <p class="card-produs__descriere card-text text-body-secondary mb-0"><%= produs.descriere %></p>
	                                        </div>

                                        <div class="row row-cols-1 row-cols-sm-2 g-2 small">
                                            <div class="col">
                                                <div class="card-produs__detaliu p-2 rounded">
                                                    <b>Pret:</b> <span><%= Number(produs.pret).toFixed(2) %> lei</span>
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="card-produs__detaliu p-2 rounded">
                                                    <b>Tip produs:</b> <span><%= produs.subcategorie %></span>
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="card-produs__detaliu p-2 rounded">
                                                    <b>Culoare:</b> <span><%= produs.culoare %></span>
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="card-produs__detaliu p-2 rounded">
                                                    <b>Taguri:</b> <span><%= produs.taguri %></span>
                                                </div>
                                            </div>
                                            <div class="col col-sm-12">
                                                <div class="card-produs__detaliu p-2 rounded">
                                                    <b>Data adaugare:</b> <time datetime="<%= dataAfisata.iso %>"><%= dataAfisata.text %></time>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card-footer bg-transparent border-0 pt-0">
                                        <a class="btn btn-outline-primary w-100" href="/produs/<%= produs.id %>">
                                            <i class="bi bi-arrow-right-circle-fill me-2" aria-hidden="true"></i>Vezi pagina produsului
                                        </a>
                                    </div>
                                </div>
	                            </article>
	                        <% } %>
	                    </div>

	                    <div class="modale-produse" aria-label="Detalii rapide produse">
	                        <% for (const produs of listaProduse) { %>
	                            <%
	                                const dataAfisata = dataProdus(produs.data_adaugare);
	                                const taguriProdus = produs.taguri.split(",").map((tag) => tag.trim()).filter(Boolean);
	                                const imaginiProdus = Array.isArray(produs.imagini) && produs.imagini.length
	                                    ? produs.imagini
	                                    : [{ src: produs.imagine, alt: `${produs.nume} - imagine principala` }];
	                            %>
	                            <dialog class="modal-produs" id="modal-produs-<%= produs.id %>" aria-labelledby="titlu-modal-produs-<%= produs.id %>">
	                                <div class="modal-produs__continut">
	                                    <header class="modal-produs__header">
	                                        <h3 id="titlu-modal-produs-<%= produs.id %>"><%= produs.nume %></h3>
	                                        <button class="modal-produs__inchide" type="button" aria-label="Inchide detaliile produsului" data-modal-inchide>
	                                            <i class="bi bi-x-lg" aria-hidden="true"></i>
	                                        </button>
	                                    </header>

	                                    <article class="produs-unic__card modal-produs__card">
	                                        <div class="produs-unic__media">
	                                            <div class="produs-unic__galerie" data-galerie-produs>
	                                                <img
	                                                    class="produs-unic__imagine-curenta"
	                                                    src="<%= imaginiProdus[0].src %>"
	                                                    alt="<%= imaginiProdus[0].alt %>"
	                                                    data-galerie-imagine
	                                                >

	                                                <% if (imaginiProdus.length > 1) { %>
	                                                    <div class="produs-unic__galerie-actiuni" aria-label="Navigare imagini produs">
	                                                        <button class="btn btn-outline-primary" type="button" title="Imaginea precedenta" aria-label="Imaginea precedenta" data-galerie-prev>
	                                                            <i class="bi bi-chevron-left" aria-hidden="true"></i>
	                                                        </button>
	                                                        <span class="produs-unic__galerie-contor" aria-live="polite" data-galerie-contor>1 / <%= imaginiProdus.length %></span>
	                                                        <button class="btn btn-outline-primary" type="button" title="Imaginea urmatoare" aria-label="Imaginea urmatoare" data-galerie-next>
	                                                            <i class="bi bi-chevron-right" aria-hidden="true"></i>
	                                                        </button>
	                                                    </div>

	                                                    <div class="produs-unic__miniaturi" aria-label="Selectare imagine produs">
	                                                        <% imaginiProdus.forEach(function (imagine, index) { %>
	                                                            <button
	                                                                class="produs-unic__miniatura <%= index === 0 ? "produs-unic__miniatura--activa" : "" %>"
	                                                                type="button"
	                                                                aria-label="Afiseaza imaginea <%= index + 1 %>"
	                                                                aria-pressed="<%= index === 0 ? "true" : "false" %>"
	                                                                data-galerie-index="<%= index %>"
	                                                                data-galerie-src="<%= imagine.src %>"
	                                                                data-galerie-alt="<%= imagine.alt %>"
	                                                            >
	                                                                <img src="<%= imagine.src %>" alt="">
	                                                            </button>
	                                                        <% }) %>
	                                                    </div>
	                                                <% } %>
	                                            </div>
	                                        </div>

	                                        <p class="produs-unic__descriere"><%= produs.descriere %></p>

	                                        <div class="produs-unic__detalii produs-unic__detalii--principale">
	                                            <p><b>ID:</b> <span><%= produs.id %></span></p>
	                                            <p><b>Categorie:</b> <span><%= produs.categorie %></span></p>
	                                            <p><b>Subcategorie:</b> <span><%= produs.subcategorie %></span></p>
	                                            <p><b>Pret:</b> <span><%= Number(produs.pret).toFixed(2) %> lei</span></p>
	                                        </div>

	                                        <div class="produs-unic__detalii produs-unic__detalii--secundare">
	                                            <p><b>Greutate:</b> <span><%= produs.greutate_grame %> g</span></p>
	                                            <p><b>Data adaugare:</b> <time datetime="<%= dataAfisata.iso %>"><%= dataAfisata.text %></time></p>
	                                            <p><b>Culoare:</b> <span><%= produs.culoare %></span></p>
	                                            <p><b>Editie limitata:</b> <span><%= produs.editie_limitata ? "da" : "nu" %></span></p>
	                                            <p><b>Stoc disponibil:</b> <span><%= produs.stoc %></span></p>

	                                            <div class="produs-unic__taguri">
	                                                <b>Taguri:</b>
	                                                <ul>
	                                                    <% for (const tag of taguriProdus) { %>
	                                                        <li><%= tag %></li>
	                                                    <% } %>
	                                                </ul>
	                                            </div>
	                                        </div>
	                                    </article>
	                                </div>
	                            </dialog>
	                        <% } %>
	                    </div>
	                <% } else { %>
	                    <p>Nu exista produse de afisat momentan.</p>
	                <% } %>
            </section>
        </div>
    </main>

    <%- include("../fragmente/footer") %>
    <script src="/resurse/js/produse.js"></script>
</body>

</html>
